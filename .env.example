# PostgreSQL connection (set by docker-compose from DB_PASSWORD)
DATABASE_URL=postgres://voicedoc:changeme@localhost:5432/voicedoc

# Auth.js — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Initial admin user (used by npm run db:seed only)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Docker Compose DB password
DB_PASSWORD=changeme

# Instance-level trigger defaults (optional — fall back to "Computer" / "Assistant")
COMMAND_TRIGGER_DEFAULT=Computer
AI_TRIGGER_DEFAULT=Assistant

# SMTP for share invite emails (all optional — sharing still works without email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=smtp-password
